  id              String   @id @default(cuid())
  externalId      String   @unique
  name            String
  totalPercentage Decimal  @default(0) @db.Decimal(8, 4)
  isActive        Boolean  @default(true)
  taxes           Json?
  sourcePayload   Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive])
  @@map("tax_group_setups")
}

model DiscountSetup {
  id            String   @id @default(cuid())
  externalId    String   @unique
  name          String
  discountType  String?
  value         Decimal? @db.Decimal(14, 4)
  isActive      Boolean  @default(true)
  sourcePayload Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
  @@map("discount_setups")
}
