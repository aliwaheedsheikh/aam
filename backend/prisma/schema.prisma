generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  GENERAL_MANAGER
  FRONT_OFFICE
  ACCOUNTS
  BANQUET_CHEF
  RESTAURANT_CHEF
  HR_MANAGER
  ADMIN
}

enum SpaceType {
  PRIME
  SUB
}

enum BookingStatus {
  DRAFT
  PRICE_QUOTED
  TENTATIVE
  CONFIRMED
  COMPLETED
  CANCELLED
  EXPIRED
  LOST_SPACE_TAKEN
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum BookingSpaceAssignmentType {
  PRIME_FULL
  SUB_ONLY
}

enum ServiceType {
  VENUE_BOOKING
  OUTDOOR_CATERING
  FOOD_SUPPLY
  RENTAL_SERVICES
  MIXED_PACKAGE
}

enum ServiceStatus {
  TENTATIVE
  CONFIRMED
  COMPLETED
  CANCELLED
  EXPIRED
}

model User {
  id           String             @id @default(cuid())
  email        String             @unique
  username     String?            @unique
  passwordHash String
  fullName     String
  role         UserRole
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  bookings     Booking[]          @relation("BookingCreatedBy")
  auditLogs    AuditLog[]
  permissions  UserModuleAccess[]
}

model UserModuleAccess {
  id         String   @id @default(cuid())
  userId     String
  moduleKey  String
  canView    Boolean  @default(false)
  canCreate  Boolean  @default(false)
  canEdit    Boolean  @default(false)
  canDelete  Boolean  @default(false)
  canApprove Boolean  @default(false)
  canExport  Boolean  @default(false)
  canManage  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleKey])
  @@index([moduleKey])
}

model Customer {
  id           String    @id @default(cuid())
  fullName     String
  phone        String    @unique
  email        String?
  address      String?
  customerType String?
  companyName  String?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  bookings     Booking[]
}

model Venue {
  id        String    @id @default(cuid())
  code      String    @unique
  name      String
  location  String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  spaces    Space[]
  bookings  Booking[]
}

model Space {
  id            String    @id @default(cuid())
  code          String    @unique
  venueId       String
  parentSpaceId String?
  name          String
  type          SpaceType
  capacity      Int?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  venue         Venue     @relation(fields: [venueId], references: [id], onDelete: Cascade)
  parentSpace   Space?    @relation("SpaceHierarchy", fields: [parentSpaceId], references: [id])
  childSpaces   Space[]   @relation("SpaceHierarchy")
}

model Booking {
  id                String                        @id @default(cuid())
  bookingNumber     String                        @unique
  externalId        String?                       @unique
  customerId        String
  venueId           String
  createdById       String?
  status            BookingStatus
  paymentStatus     PaymentStatus                 @default(PENDING)
  eventType         String?
  bookingSource     String?
  notes             String?
  guestCount        Int
  eventDate         DateTime
  startTime         String
  endTime           String
  totalAmount       Decimal?                      @db.Decimal(12, 2)
  paidAmount        Decimal?                      @db.Decimal(12, 2)
  balanceAmount     Decimal?                      @db.Decimal(12, 2)
  sourcePayload     Json?
  createdAt         DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt
  customer          Customer                      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  venue             Venue                         @relation(fields: [venueId], references: [id], onDelete: Restrict)
  createdBy         User?                         @relation("BookingCreatedBy", fields: [createdById], references: [id])
  spaceAssignments  BookingSpaceAssignment[]
  payments          Payment[]
  additionalCharges ReservationAdditionalCharge[]
  auditLogs         AuditLog[]
}

model AdditionalChargeType {
  id                 String                        @id @default(cuid())
  name               String                        @unique
  defaultRate        Decimal                       @default(0) @map("default_rate") @db.Decimal(12, 2)
  unitType           String                        @default("fixed") @map("unit_type")
  defaultDescription String                        @default("") @map("default_description")
  isActive           Boolean                       @default(true) @map("is_active")
  createdAt          DateTime                      @default(now()) @map("created_at")
  updatedAt          DateTime                      @updatedAt @map("updated_at")
  reservationCharges ReservationAdditionalCharge[]

  @@map("additional_charge_types")
}

model ReservationAdditionalCharge {
  id                     String                @id @default(cuid())
  reservationId          String                @map("reservation_id")
  additionalChargeTypeId String?               @map("additional_charge_type_id")
  customChargeName       String?               @map("custom_charge_name")
  description            String                @default("")
  quantity               Decimal               @default(1) @db.Decimal(12, 2)
  rate                   Decimal               @default(0) @db.Decimal(12, 2)
  total                  Decimal               @default(0) @db.Decimal(12, 2)
  notes                  String?
  createdAt              DateTime              @default(now()) @map("created_at")
  updatedAt              DateTime              @updatedAt @map("updated_at")
  reservation            Booking               @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  additionalChargeType   AdditionalChargeType? @relation(fields: [additionalChargeTypeId], references: [id], onDelete: SetNull)

  @@index([reservationId])
  @@index([additionalChargeTypeId])
  @@map("reservation_additional_charges")
}

model BookingSpaceAssignment {
  id             String                     @id @default(cuid())
  bookingId      String
  venueId        String
  primeSpaceId   String
  subSpaceId     String?
  assignmentType BookingSpaceAssignmentType
  usageLabel     String?
  sortOrder      Int                        @default(0)
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  booking        Booking                    @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([venueId, primeSpaceId])
  @@index([venueId, subSpaceId])
}

model Payment {
  id        String   @id @default(cuid())
  bookingId String
  amount    Decimal  @db.Decimal(12, 2)
  method    String
  reference String?
  paidAt    DateTime
  notes     String?
  createdAt DateTime @default(now())
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  bookingId  String?
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])
  booking    Booking? @relation(fields: [bookingId], references: [id])
}

model MasterDataRecord {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServiceBooking {
  id            String        @id @default(cuid())
  externalId    String        @unique
  serviceType   ServiceType
  status        ServiceStatus
  eventDate     DateTime
  startTime     String
  endTime       String
  customerName  String
  contactNumber String
  guestCount    Int
  notes         String?
  totalAmount   Decimal?      @db.Decimal(12, 2)
  paidAmount    Decimal?      @db.Decimal(12, 2)
  balanceAmount Decimal?      @db.Decimal(12, 2)
  sourcePayload Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model ProcurementVendor {
  id                  String                 @id @default(cuid())
  externalId          String                 @unique
  vendorName          String
  vendorCode          String?
  vendorTypeExternalId String?
  vendorTypeId        String?                @map("vendor_type_id")
  supplyCategoryExternalIds Json?
  vendorCategories    Json?
  contactPerson       String?
  phone               String?
  email               String?
  address             String?
  city                String?
  paymentTerms        String?
  creditLimit         Decimal?               @db.Decimal(12, 2)
  supplyScope         String?                @map("supply_scope")
  defaultLeadTimeDays Int?                   @map("default_lead_time_days")
  orderCutoffTime     String?                @map("order_cutoff_time")
  deliveryDays        Json?                  @map("delivery_days")
  status              String
  taxId               String?
  inactiveReason      String?
  inactiveSince       DateTime?
  pricingFormulas     Json?
  currentBalance      Decimal?               @db.Decimal(12, 2)
  totalPurchases      Decimal?               @db.Decimal(12, 2)
  lastPurchaseDate    DateTime?
  createdBy           String?
  sourceCreatedAt     DateTime?
  sourceUpdatedAt     DateTime?
  sourcePayload       Json?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  vendorType          VendorType?            @relation(fields: [vendorTypeId], references: [id], onDelete: SetNull)
  supplyCategories    VendorSupplyCategory[]
  itemMappings        VendorItemMapping[]
}

model VendorType {
  id        String              @id
  name      String
  status    String              @default("active")
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")
  vendors   ProcurementVendor[]

  @@map("vendor_types")
}

model SupplyCategory {
  id        String                 @id
  name      String
  status    String                 @default("active")
  createdAt DateTime               @default(now()) @map("created_at")
  updatedAt DateTime               @updatedAt @map("updated_at")
  vendors   VendorSupplyCategory[]

  @@map("supply_categories")
}

model PurchaseCategory {
  id           String          @id
  name         String
  status       String          @default("active")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  kitchenItems InventoryItem[]

  @@map("purchase_categories")
}

model ProcurementVendorType {
  id              String   @id @default(cuid())
  externalId      String   @unique
  code            String?
  name            String
  status          String   @default("active")
  sortOrder       Int?
  createdBy       String?
  sourceCreatedAt DateTime?
  sourceUpdatedAt DateTime?
  sourcePayload   Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ProcurementSupplyCategory {
  id              String   @id @default(cuid())
  externalId      String   @unique
  code            String?
  name            String
  status          String   @default("active")
  sortOrder       Int?
  createdBy       String?
  sourceCreatedAt DateTime?
  sourceUpdatedAt DateTime?
  sourcePayload   Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ProcurementPurchaseCategory {
  id              String   @id @default(cuid())
  externalId      String   @unique
  code            String?
  name            String
  status          String   @default("active")
  sortOrder       Int?
  createdBy       String?
  sourceCreatedAt DateTime?
  sourceUpdatedAt DateTime?
  sourcePayload   Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model VendorSupplyCategory {
  vendorId         String            @map("vendor_id")
  supplyCategoryId String            @map("supply_category_id")
  vendor           ProcurementVendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  supplyCategory   SupplyCategory    @relation(fields: [supplyCategoryId], references: [id], onDelete: Cascade)

  @@id([vendorId, supplyCategoryId])
  @@index([supplyCategoryId])
  @@map("vendor_supply_categories")
}

model VendorItemMapping {
  vendorId      String            @map("vendor_id")
  kitchenItemId String            @map("kitchen_item_id")
  isPreferred   Boolean           @default(false) @map("is_preferred")
  leadTimeDays  Int?              @map("lead_time_days")
  moq           Decimal?          @db.Decimal(14, 3)
  lastRate      Decimal?          @map("last_rate") @db.Decimal(14, 4)
  contractRate  Decimal?          @map("contract_rate") @db.Decimal(14, 4)
  status        String            @default("active")
  notes         String?
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  vendor        ProcurementVendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  kitchenItem   InventoryItem     @relation(fields: [kitchenItemId], references: [id], onDelete: Cascade)

  @@id([vendorId, kitchenItemId])
  @@index([kitchenItemId])
  @@map("vendor_item_mappings")
}

model InventoryItem {
  id                        String              @id @default(cuid())
  externalId                String              @unique
  itemName                  String
  itemCode                  String?
  category                  String
  purchaseCategoryId        String?             @map("purchase_category_id")
  purchaseUnit              String
  issueUnit                 String
  conversionFactor          Decimal             @db.Decimal(14, 4)
  storeLocation             String
  currentStock              Decimal             @db.Decimal(14, 3)
  reorderLevel              Decimal             @db.Decimal(14, 3)
  lastPurchaseRate          Decimal             @db.Decimal(14, 4)
  ratePerUnit               Decimal?            @db.Decimal(14, 4)
  preferredVendorExternalId String?             @map("preferred_vendor")
  legacyPreferredVendorExternalId String?       @map("preferredVendorExternalId")
  alternateVendorExternalIds Json?
  leadTimeDays              Int?
  minimumOrderQuantity      Decimal?            @db.Decimal(14, 3)
  legacyPurchaseCategoryExternalId String?      @map("purchaseCategoryExternalId")
  supplyCategoryExternalId  String?
  lastPurchaseDate          DateTime?
  status                    String
  sourceCreatedAt           DateTime?
  sourceUpdatedAt           DateTime?
  sourcePayload             Json?
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
  purchaseCategory          PurchaseCategory?   @relation(fields: [purchaseCategoryId], references: [id], onDelete: SetNull)
  vendorMappings            VendorItemMapping[]

  @@map("kitchen_items")
}

model ProcurementPurchaseOrder {
  id                   String                         @id @default(cuid())
  externalId           String                         @unique
  poNumber             String                         @unique
  vendorExternalId     String?
  vendorName           String
  orderDate            DateTime
  expectedDeliveryDate DateTime
  paymentTerms         String
  status               String
  sourceFlow           String?
  sourceLabel          String?
  subtotal             Decimal?                       @db.Decimal(14, 2)
  taxAmount            Decimal?                       @db.Decimal(14, 2)
  totalAmount          Decimal?                       @db.Decimal(14, 2)
  amountPaid           Decimal?                       @db.Decimal(14, 2)
  amountPending        Decimal?                       @db.Decimal(14, 2)
  deliveredDate        DateTime?
  receivedBy           String?
  receivedQuantities   Json?
  remarks              String?
  createdBy            String?
  approvedBy           String?
  approvedAt           DateTime?
  sourceCreatedAt      DateTime?
  sourceUpdatedAt      DateTime?
  sourcePayload        Json?
  createdAt            DateTime                       @default(now())
  updatedAt            DateTime                       @updatedAt
  items                ProcurementPurchaseOrderItem[]
}

model ProcurementPurchaseOrderItem {
  id                         String                   @id @default(cuid())
  purchaseOrderId            String
  sourceItemId               String?
  purchaseItemExternalId     String?
  itemName                   String
  preferredVendorExternalId  String?
  selectedVendorExternalId   String?
  purchaseCategoryExternalId String?
  supplyCategoryExternalId   String?
  quantity                   Decimal                  @db.Decimal(14, 3)
  unit                       String
  ratePerUnit                Decimal                  @db.Decimal(14, 4)
  amount                     Decimal                  @db.Decimal(14, 2)
  receivedQuantity           Decimal?                 @db.Decimal(14, 3)
  pendingQuantity            Decimal?                 @db.Decimal(14, 3)
  sourcePayload              Json?
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt
  purchaseOrder              ProcurementPurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
}

model ProcurementGoodsReceipt {
  id                      String                        @id @default(cuid())
  externalId              String                        @unique
  grnNumber               String                        @unique
  purchaseOrderId         String?
  purchaseOrderExternalId String?
  poNumber                String
  vendorExternalId        String?
  vendorName              String
  receiptDate             DateTime
  destinationStore        String
  qualityCheckStatus      String
  qualityCheckedBy        String?
  qualityRemarks          String?
  receivedBy              String?
  sourceCreatedAt         DateTime?
  sourcePayload           Json?
  createdAt               DateTime                      @default(now())
  updatedAt               DateTime                      @updatedAt
  items                   ProcurementGoodsReceiptItem[]
}

model ProcurementGoodsReceiptItem {
  id                     String                  @id @default(cuid())
  goodsReceiptId         String
  purchaseItemExternalId String?
  itemName               String
  orderedQuantity        Decimal                 @db.Decimal(14, 3)
  receivedQuantity       Decimal                 @db.Decimal(14, 3)
  acceptedQuantity       Decimal                 @db.Decimal(14, 3)
  rejectedQuantity       Decimal                 @db.Decimal(14, 3)
  unit                   String
  ratePerUnit            Decimal                 @db.Decimal(14, 4)
  totalValue             Decimal                 @db.Decimal(14, 2)
  sourcePayload          Json?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  goodsReceipt           ProcurementGoodsReceipt @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)

  @@index([goodsReceiptId])
}

model InventoryStoreStock {
  id                     String   @id @default(cuid())
  externalKey            String   @unique
  storeLocation          String
  purchaseItemExternalId String
  itemName               String
  currentStock           Decimal  @db.Decimal(14, 3)
  unit                   String
  reorderLevel           Decimal  @db.Decimal(14, 3)
  lastUpdatedAt          DateTime
  sourcePayload          Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([storeLocation])
  @@index([purchaseItemExternalId])
}

model InventoryStockTransfer {
  id              String                       @id @default(cuid())
  externalId      String                       @unique
  transferNumber  String                       @unique
  transferDate    DateTime
  fromStore       String
  toStore         String
  status          String
  issuedBy        String?
  receivedBy      String?
  receivedAt      DateTime?
  remarks         String?
  sourceCreatedAt DateTime?
  sourcePayload   Json?
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt
  items           InventoryStockTransferItem[]
}

model InventoryStockTransferItem {
  id                     String                 @id @default(cuid())
  stockTransferId        String
  purchaseItemExternalId String?
  itemName               String
  quantity               Decimal                @db.Decimal(14, 3)
  unit                   String
  status                 String
  sourcePayload          Json?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  stockTransfer          InventoryStockTransfer @relation(fields: [stockTransferId], references: [id], onDelete: Cascade)

  @@index([stockTransferId])
}

model ProcurementVendorBill {
  id                      String                      @id @default(cuid())
  externalId              String                      @unique
  billNumber              String                      @unique
  vendorBillNumber        String?
  billDate                DateTime
  dueDate                 DateTime
  vendorExternalId        String?
  vendorName              String
  purchaseOrderExternalId String?
  poNumber                String?
  subtotal                Decimal?                    @db.Decimal(14, 2)
  taxRate                 Decimal?                    @db.Decimal(8, 4)
  taxAmount               Decimal?                    @db.Decimal(14, 2)
  totalAmount             Decimal?                    @db.Decimal(14, 2)
  amountPaid              Decimal?                    @db.Decimal(14, 2)
  amountPending           Decimal?                    @db.Decimal(14, 2)
  status                  String
  remarks                 String?
  createdBy               String?
  sourceCreatedAt         DateTime?
  sourceUpdatedAt         DateTime?
  sourcePayload           Json?
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  items                   ProcurementVendorBillItem[]
  payments                ProcurementVendorPayment[]
}

model ProcurementVendorBillItem {
  id                     String                @id @default(cuid())
  vendorBillId           String
  sourceItemId           String?
  purchaseItemExternalId String?
  itemName               String
  quantity               Decimal               @db.Decimal(14, 3)
  unit                   String
  ratePerUnit            Decimal               @db.Decimal(14, 4)
  amount                 Decimal               @db.Decimal(14, 2)
  sourcePayload          Json?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  vendorBill             ProcurementVendorBill @relation(fields: [vendorBillId], references: [id], onDelete: Cascade)

  @@index([vendorBillId])
}

model ProcurementVendorPayment {
  id               String                @id @default(cuid())
  vendorBillId     String
  sourcePaymentId  String?
  voucherNumber    String?
  paymentDate      DateTime
  vendorExternalId String?
  vendorName       String
  amount           Decimal               @db.Decimal(14, 2)
  paymentMethod    String
  paymentReference String?
  bankName         String?
  chequeNumber     String?
  chequeDate       DateTime?
  approvedBy       String?
  approvedAt       DateTime?
  remarks          String?
  paidBy           String?
  sourceCreatedAt  DateTime?
  sourcePayload    Json?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  vendorBill       ProcurementVendorBill @relation(fields: [vendorBillId], references: [id], onDelete: Cascade)

  @@index([vendorBillId])
}

model BanquetCuisine {
  id                String   @id @default(cuid())
  externalId        String   @unique
  code              String?
  name              String
  module            String
  status            String
  description       String?
  linkedDishesCount Int?
  createdBy         String?
  updatedBy         String?
  sourceCreatedAt   DateTime?
  sourceUpdatedAt   DateTime?
  sourcePayload     Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([module])
  @@index([status])
  @@map("banquet_cuisines")
}

model KitchenStationMaster {
  id                   String   @id @default(cuid())
  externalId           String   @unique
  code                 String?
  name                 String
  module               String
  productionType       String?
  linkedStoreExternalId String?
  linkedStoreName      String?
  linkedStoreLocation  String?
  status               String
  description          String?
  notes                String?
  linkedDishesCount    Int?
  linkedRecipesCount   Int?
  createdBy            String?
  updatedBy            String?
  sourceCreatedAt      DateTime?
  sourceUpdatedAt      DateTime?
  sourcePayload        Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([module])
  @@index([status])
  @@map("kitchen_station_masters")
}

model KitchenDishCategoryMaster {
  id                String   @id @default(cuid())
  externalId        String   @unique
  code              String?
  name              String
  module            String
  status            String
  description       String?
  notes             String?
  linkedDishesCount Int?
  createdBy         String?
  updatedBy         String?
  sourceCreatedAt   DateTime?
  sourceUpdatedAt   DateTime?
  sourcePayload     Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([module])
  @@index([status])
  @@map("kitchen_dish_category_masters")
}

model MeasurementUnitMaster {
  id               String   @id @default(cuid())
  externalId       String   @unique
  code             String
  name             String
  symbol           String
  family           String
  baseUnitCode     String?
  conversionToBase Decimal? @db.Decimal(14, 6)
  allowPurchase    Boolean  @default(false)
  allowIssue       Boolean  @default(false)
  allowRecipe      Boolean  @default(false)
  allowYield       Boolean  @default(false)
  allowSales       Boolean  @default(false)
  status           String
  notes            String?
  createdBy        String?
  sourceCreatedAt  DateTime?
  sourceUpdatedAt  DateTime?
  sourcePayload    Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([family])
  @@index([status])
  @@map("measurement_unit_masters")
}

model KitchenStoreMaster {
  id             String   @id @default(cuid())
  externalId     String   @unique
  code           String
  name           String
  kind           String
  purpose        String
  parentStoreId  String?
  status         String
  notes          String?
  createdBy      String?
  sourceCreatedAt DateTime?
  sourceUpdatedAt DateTime?
  sourcePayload  Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@map("kitchen_store_masters")
}

model BanquetDish {
  id                      String   @id @default(cuid())
  externalId              String   @unique
  dishCode                String?
  dishName                String
  cuisineExternalId       String?
  cuisineName             String?
  categoryExternalId      String?
  category                String?
  module                  String
  kitchenStationExternalId String?
  preparationArea         String?
  sourceType              String?
  productionType          String?
  issuedFrom              String?
  unitOfSale              String?
  status                  String
  description             String?
  hasRecipe               Boolean  @default(false)
  recipeExternalId        String?
  estimatedCost           Decimal? @db.Decimal(14, 4)
  costPerBaseUnit         Decimal? @db.Decimal(14, 4)
  sellingPrice            Decimal? @db.Decimal(14, 4)
  recipeCost              Decimal? @db.Decimal(14, 4)
  defaultVariantCost      Decimal? @db.Decimal(14, 4)
  defaultSellingPrice     Decimal? @db.Decimal(14, 4)
  foodCostPercentage      Decimal? @db.Decimal(8, 4)
  grossMargin             Decimal? @db.Decimal(8, 4)
  createdBy               String?
  updatedBy               String?
